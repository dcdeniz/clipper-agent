# ---- LLM / Transcription ----
# Groq — used for Whisper transcription (whisper-large-v3-turbo)
GROQ_API_KEY=

# Anthropic — used for clip research (segment scoring) and caption writing
ANTHROPIC_API_KEY=
# Model overrides (optional; sensible defaults applied in config)
CLIPPER_RESEARCH_MODEL=claude-haiku-4-5
CLIPPER_CAPTION_MODEL=claude-sonnet-4-6

# ---- Publishing: TikTok (Content Posting API) ----
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# ---- Publishing: Instagram (Graph API) ----
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# ---- Publishing: YouTube (Data API) ----
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ---- Binaries (optional — resolved from PATH if unset) ----
CLIPPER_FFMPEG_PATH=
CLIPPER_YT_DLP_PATH=

# ---- Runtime ----
# Override the OS-default data directory (downloads, work queue, clips, logs)
CLIPPER_DATA_DIR=
# Logging: trace | debug | info | warn | error
LOG_LEVEL=info
# pretty (dev) | json (prod)
LOG_FORMAT=pretty
